{
  "name": "Gavo V3 API Validation Schema",
  "description": "Validation constraints for Gavo V3 API requests.",
  "rules": [
    {
      "method": "POST",
      "pathPattern": "/users/register",
      "schema": {
        "type": "object",
        "required": ["name", "password", "username", "email", "organization_id"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "password": { "type": "string", "minLength": 8 },
          "username": { "type": "string", "minLength": 3 },
          "email": { "type": "string", "format": "email" },
          "organization_id": { "type": "string", "pattern": "^[0-9a-fA-F-]{36}$" },
          "roles": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "method": "POST",
      "pathPattern": "/users/login",
      "schema": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      }
    },
    {
      "method": "POST",
      "pathPattern": "/organizations",
      "schema": {
        "type": "object",
        "required": ["name", "contact_email", "contact_phone"],
        "properties": {
          "name": { "type": "string" },
          "contact_email": { "type": "string", "format": "email" },
          "contact_phone": { "type": "string" },
          "metadata": { "type": "array" }
        }
      }
    },
    {
      "method": "POST",
      "pathPattern": "/transactions",
      "schema": {
        "type": "object",
        "required": ["service_code", "phone", "amount", "external_id"],
        "properties": {
          "service_code": { "type": "string" },
          "phone": { "type": "string" },
          "amount": { "type": ["string", "number"] },
          "external_id": { "type": "string" }
        }
      }
    },
    {
      "method": "POST",
      "pathPattern": "/dispatch/single",
      "schema": {
        "type": "object",
        "required": ["service_id", "fulfillment_product_id", "recipient_identifier", "amount"],
        "properties": {
          "service_id": { "type": "string", "pattern": "^[0-9a-fA-F-]{36}$" },
          "fulfillment_product_id": { "type": "string", "pattern": "^[0-9a-fA-F-]{36}$" },
          "recipient_identifier": { "type": "string" },
          "amount": { "type": "number", "minimum": 1 }
        }
      }
    }
  ]
}
